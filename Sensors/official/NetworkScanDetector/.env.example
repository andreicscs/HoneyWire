# Core HoneyWire configuration
HW_HUB_ENDPOINT=http://192.168.1.100:8080
HW_HUB_KEY=change_this_to_a_secure_random_string
HW_SENSOR_ID=port-scan-detector-01
HW_SEVERITY=high

# The number of unique closed ports a single IP must hit within the time window
HW_SCAN_THRESHOLD=5

# The time window for scan detection in seconds
HW_SCAN_WINDOW=5

# Ports that should be ignored because they are legitimately open on the host
HW_IGNORE_PORTS=80,443
