# Core HoneyWire configuration
HW_HUB_ENDPOINT=http://192.168.1.100:8080
HW_HUB_KEY=change_this_to_a_secure_random_string
HW_SENSOR_ID=file-watcher-canary-01
HW_SEVERITY=critical

# Host directory mounted into the container for monitoring
HW_HONEY_DIR=/honey_dir

# Optional: Observer polling interval in seconds
HW_POLLING_INTERVAL=1
